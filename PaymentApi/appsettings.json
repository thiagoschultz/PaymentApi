{
  "ReverseProxy": {
    "Routes": {

      "payment": {
        "ClusterId": "paymentCluster",
        "Match": {
          "Path": "/payments/{**catch-all}"
        }
      }

    },

    "Clusters": {

      "paymentCluster": {
        "Destinations": {
          "dest1": {
            "Address": "http://paymentapi/"
          }
        }
      }

    }

  }
}